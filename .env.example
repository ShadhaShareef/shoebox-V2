# ============================================================
# SHOEBOX — Environment Configuration (PHP / XAMPP)
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

APP_NAME=SHOEBOX
APP_ENV=local
APP_DEBUG=false
APP_URL=/shoebox2

# Set true when serving over HTTPS in production
SESSION_SECURE=false

# MySQL (XAMPP defaults)
DB_HOST=localhost
DB_NAME=shoebox_db
DB_USER=root
DB_PASS=

# Commerce
FREE_SHIPPING_THRESHOLD=15000
SHIPPING_FEE=350
CURRENCY=₹

# Razorpay — https://dashboard.razorpay.com/app/keys
# Test keys start with rzp_test_; live keys with rzp_live_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook secret from Razorpay Dashboard → Webhooks (production)
RAZORPAY_WEBHOOK_SECRET=

# UPI VPA shown on QR (your Razorpay-linked VPA in live mode)
RAZORPAY_UPI_VPA=shoebox@razorpay

# Set false when using real Razorpay test/live keys
RAZORPAY_MOCK_MODE=true
